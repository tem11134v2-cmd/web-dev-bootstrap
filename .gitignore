# Bootstrap repo — это шаблон, не Next.js проект.
# Этот .gitignore уезжает в новый проект и начинает работать там.

# Node / Next.js
node_modules/
.next/
out/
dist/
build/
*.tsbuildinfo
next-env.d.ts

# Env / secrets
.env
.env.local
.env.*.local
.env.production
.env.development
*.key
*.pem

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pm2/

# Runtime data
data/leads.json
data/*.sqlite
data/*.db

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*.swo

# Claude Code session state (memory/ файлы уезжают, state — нет)
.claude/settings.local.json
.claude/state/
.claude/cache/

# Test / coverage
coverage/
.nyc_output/

# Misc
.cache/
tmp/
temp/
