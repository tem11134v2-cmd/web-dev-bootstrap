# Шаблон GitHub Actions workflow для push-based deploy production.
#
# Куда положить: .github/workflows/deploy-prod.yml в корне сайта (после спеки 01b).
# Что меняется per-site: vars.SITE_NAME (имя сайта = имя PM2-процесса).
#
# Что нужно настроить ПЕРЕД первым push (см. deploy/README.md):
#   1. GitHub Environment "production" с required reviewers (опционально, чтобы
#      деплой требовал одобрения).
#   2. Secrets в environment "production":
#        SSH_PRIVATE_KEY  — приватный ключ ed25519 (single-purpose deploy key,
#                           публичная часть в /home/deploy/.ssh/authorized_keys на VPS)
#        SSH_HOST         — IP VPS
#        SSH_USER         — deploy
#        SSH_PORT         — 2222 (или 22, если кастомный порт не настраивался)
#        PROD_ENV_FILE    — содержимое .env.production целиком (multiline secret)
#      Опционально (если используются на билде):
#        NEXT_PUBLIC_TURNSTILE_SITE_KEY
#        NEXT_PUBLIC_YM_ID
#        NEXT_PUBLIC_GA_ID
#   3. Repository variable SITE_NAME = имя сайта (например, "migrator").
#
# Логика:
#   build  — собирает .next/standalone на ubuntu-latest, упаковывает в artifact
#   deploy — скачивает artifact, rsync-ит в releases/<sha>/ на VPS, пушит .env
#            из секрета, переключает симлинк current/, делает pm2 reload,
#            подчищает старые релизы (оставляет последние 5).
#
# concurrency не отменяет идущий деплой, а ставит следующий в очередь — иначе
# два параллельных rsync-а в одну папку могут испортить артефакт.

name: Deploy production

on:
  push:
    branches: [main]
  workflow_dispatch:

concurrency:
  group: deploy-prod-${{ vars.SITE_NAME }}
  cancel-in-progress: false

jobs:
  build:
    name: Build standalone artifact
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: pnpm/action-setup@v4
        with:
          version: latest

      - uses: actions/setup-node@v4
        with:
          node-version: 22
          cache: pnpm

      - name: Install dependencies
        run: pnpm install --frozen-lockfile

      - name: Build
        run: pnpm build
        env:
          NEXT_TELEMETRY_DISABLED: 1
          NEXT_PUBLIC_TURNSTILE_SITE_KEY: ${{ secrets.NEXT_PUBLIC_TURNSTILE_SITE_KEY }}
          NEXT_PUBLIC_YM_ID: ${{ secrets.NEXT_PUBLIC_YM_ID }}
          NEXT_PUBLIC_GA_ID: ${{ secrets.NEXT_PUBLIC_GA_ID }}

      - name: Pack standalone bundle
        # standalone-сборка кладёт server.js + минимальные node_modules в .next/standalone.
        # Статику и public надо положить рядом — Next их не копирует автоматически.
        run: |
          mkdir -p deploy/.next
          cp -r .next/standalone/. deploy/
          cp -r .next/static deploy/.next/static
          cp -r public deploy/public

      - uses: actions/upload-artifact@v4
        with:
          name: app
          path: deploy
          retention-days: 5
          if-no-files-found: error

  deploy:
    name: Rsync to VPS and switch symlink
    needs: build
    runs-on: ubuntu-latest
    environment: production
    steps:
      - uses: actions/download-artifact@v4
        with:
          name: app
          path: deploy

      - name: Setup SSH
        run: |
          mkdir -p ~/.ssh
          echo "${{ secrets.SSH_PRIVATE_KEY }}" > ~/.ssh/id_ed25519
          chmod 600 ~/.ssh/id_ed25519
          ssh-keyscan -p ${{ secrets.SSH_PORT || 22 }} -H ${{ secrets.SSH_HOST }} \
            >> ~/.ssh/known_hosts

      - name: Rsync to release dir
        env:
          SSH: ssh -i ~/.ssh/id_ed25519 -p ${{ secrets.SSH_PORT || 22 }}
          TARGET: ${{ secrets.SSH_USER }}@${{ secrets.SSH_HOST }}
          RELEASE_DIR: /home/deploy/prod/${{ vars.SITE_NAME }}/releases/${{ github.sha }}
        run: |
          $SSH $TARGET "mkdir -p $RELEASE_DIR"
          rsync -az --delete -e "$SSH" deploy/ $TARGET:$RELEASE_DIR/

      - name: Push .env from secrets
        env:
          SSH: ssh -i ~/.ssh/id_ed25519 -p ${{ secrets.SSH_PORT || 22 }}
          TARGET: ${{ secrets.SSH_USER }}@${{ secrets.SSH_HOST }}
          ENV_FILE: /home/deploy/prod/${{ vars.SITE_NAME }}/releases/${{ github.sha }}/.env
        run: |
          $SSH $TARGET "cat > $ENV_FILE && chmod 600 $ENV_FILE" <<'EOF'
          ${{ secrets.PROD_ENV_FILE }}
          EOF

      - name: Activate release (atomic symlink switch)
        env:
          SSH: ssh -i ~/.ssh/id_ed25519 -p ${{ secrets.SSH_PORT || 22 }}
          TARGET: ${{ secrets.SSH_USER }}@${{ secrets.SSH_HOST }}
          SITE_DIR: /home/deploy/prod/${{ vars.SITE_NAME }}
          SHA: ${{ github.sha }}
          PM2_NAME: ${{ vars.SITE_NAME }}-prod
        run: |
          $SSH $TARGET "set -e; \
            ln -sfn $SITE_DIR/releases/$SHA $SITE_DIR/current; \
            pm2 reload $PM2_NAME --update-env || \
              pm2 start $SITE_DIR/current/server.js --name $PM2_NAME --update-env; \
            pm2 save"

      - name: Cleanup old releases (keep last 5)
        env:
          SSH: ssh -i ~/.ssh/id_ed25519 -p ${{ secrets.SSH_PORT || 22 }}
          TARGET: ${{ secrets.SSH_USER }}@${{ secrets.SSH_HOST }}
          RELEASES_DIR: /home/deploy/prod/${{ vars.SITE_NAME }}/releases
        run: |
          $SSH $TARGET "cd $RELEASES_DIR && ls -1tr | head -n -5 | xargs -r rm -rf"
